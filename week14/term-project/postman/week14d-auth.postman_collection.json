{
  "info": {
    "name": "Week14d Auth + Admin Routes",
    "_postman_id": "3e2a9e3a-1f2f-4dc2-9f6c-8c6b4d6a8d0f",
    "description": "Postman collection for Week 14d login, session, and admin-protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /auth/login (admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /auth/session",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/session",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "session"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET /admin/dashboard (requires admin session)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "dashboard"
          ]
        }
      },
      "response": []
    },
    {
      "name": "PUT /admin/properties/:id (requires admin session)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Updated by admin from Postman test.\",\n  \"amenities\": [\n    \"WiFi\",\n    \"Surfboard storage\",\n    \"Outdoor shower\",\n    \"Parking\",\n    \"Washer\",\n    \"Jeep or Tacoma rental available\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/properties/{{propertyId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "properties",
            "{{propertyId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST /auth/logout",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST /auth/login (visitor)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"visitor\",\n  \"password\": \"User123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET /admin/dashboard as visitor (expect 403)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "dashboard"
          ]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 403 for non-admin', function () {",
              "  pm.response.to.have.status(403);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "propertyId",
      "value": "replace_with_actual_property_id"
    }
  ]
}
