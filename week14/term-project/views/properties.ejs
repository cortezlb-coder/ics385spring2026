<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hawaii Properties</title>
    <style>
      :root {
        --bg: #f4f7fb;
        --card: #ffffff;
        --text: #1b2a3a;
        --muted: #5b6b7a;
        --accent: #0f766e;
      }

      body {
        margin: 0;
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(180deg, #eaf3ff 0%, var(--bg) 55%);
        color: var(--text);
      }

      main {
        max-width: 980px;
        margin: 2rem auto;
        padding: 0 1rem 2rem;
      }

      h1 {
        margin-bottom: 0.5rem;
      }

      .sub {
        color: var(--muted);
        margin-top: 0;
      }

      .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 1rem 0 1.5rem;
      }

      .toolbar input,
      .toolbar button {
        padding: 0.6rem 0.7rem;
        border: 1px solid #d0dae6;
        border-radius: 0.5rem;
        font-size: 0.95rem;
      }

      .toolbar button {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        cursor: pointer;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
      }

      .card {
        background: var(--card);
        border: 1px solid #dde5ee;
        border-radius: 0.8rem;
        padding: 1rem;
        box-shadow: 0 8px 20px rgba(16, 24, 40, 0.06);
      }

      .meta {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .amenities {
        margin: 0.7rem 0 0;
        padding-left: 1rem;
      }

      .reviews {
        margin-top: 0.6rem;
        font-size: 0.9rem;
      }

      .empty {
        background: #fff8e1;
        border: 1px solid #f5e3aa;
        padding: 1rem;
        border-radius: 0.7rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Properties</h1>
      <p class="sub">Week 11: UI connected to MongoDB with Mongoose.</p>

      <form method="GET" action="/properties" class="toolbar">
        <input
          type="text"
          name="island"
          placeholder="Filter by island (e.g., Maui)"
          value="<%= filters.island %>"
        />
        <input
          type="number"
          name="minRating"
          min="1"
          max="5"
          step="0.1"
          placeholder="Minimum rating"
          value="<%= filters.minRating %>"
        />
        <button type="submit">Apply Filters</button>
      </form>

      <% if (!properties.length) { %>
      <div class="empty">No properties matched your filters.</div>
      <% } %>

      <section class="grid">
        <% properties.forEach((property) => { %>
        <article class="card">
          <h2><%= property.name %></h2>
          <p class="meta"><%= property.island %> | <%= property.type %></p>
          <p><%= property.description %></p>
          <p class="meta">Target segment: <%= property.targetSegment %></p>

          <ul class="amenities">
            <% property.amenities.forEach((amenity) => { %>
            <li><%= amenity %></li>
            <% }) %>
          </ul>

          <div class="reviews">
            Reviews: <%= property.reviews ? property.reviews.length : 0 %>
          </div>
        </article>
        <% }) %>
      </section>
    </main>
  </body>
</html>
